# ==== アプリ ====
APP_URL=http://localhost:3000

# ==== DB (Prisma / Supabase Postgres想定) ====
DATABASE_URL="postgresql://user:password@localhost:5432/itomachi?schema=public"

# ==== Supabase (将来、認証をSupabase Authへ移行する際に使用) ====
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ==== Redis (Upstash / カウンター・キャッシュ・分散ロック) ====
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ==== Stripe (決済：サブスク/クレジット/オークション) ====
STRIPE_SECRET_KEY=
STRIPE_SUBSCRIPTION_PRICE_ID=
STRIPE_FIRST_MONTH_COUPON_ID=
STRIPE_WEBHOOK_SECRET=
# 公開キー(pk_live_... / pk_test_...)。現状の実装(Checkoutリダイレクト方式)では未使用だが、
# 将来Stripe.js埋め込み(Apple Pay明示ボタン等)を追加する場合に備えて保持しておく。
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ==== Sakana AI ====
# Claude API(2026-07-12: LLM処理はここに集約。Sakana AI環境変数は廃止)
ANTHROPIC_API_KEY=

# ==== OpenAI (Sakana AI障害時・コスト超過時の予備。設定すると自動フォールバック) ====
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ==== 公式LINE (CL22簡略版: 外部リンク誘導のみ) ====
NEXT_PUBLIC_LINE_OFFICIAL_URL=https://lin.ee/yJUpS8g

# ==== Cron (通知評価バッチ保護用) ====
CRON_SECRET=

# Supabase Auth(認証本実装 2026-07-12)。SERVICE_ROLE_KEYはレガシーユーザー遅延移行にのみ使用(サーバー専用・絶対に公開しない)
SUPABASE_SERVICE_ROLE_KEY=
