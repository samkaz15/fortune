# ==== アプリ ====
APP_URL=http://localhost:3000

# ==== DB (Prisma / Supabase Postgres想定) ====
DATABASE_URL="postgresql://user:password@localhost:5432/itomachi?schema=public"

# ==== Supabase (将来、認証をSupabase Authへ移行する際に使用) ====
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ==== Redis (Upstash / カウンター・キャッシュ・分散ロック) ====
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ==== Stripe (決済：サブスク/クレジット/オークション) ====
STRIPE_SECRET_KEY=
STRIPE_SUBSCRIPTION_PRICE_ID=
STRIPE_FIRST_MONTH_COUPON_ID=
STRIPE_WEBHOOK_SECRET=
# 公開キー(pk_live_... / pk_test_...)。現状の実装(Checkoutリダイレクト方式)では未使用だが、
# 将来Stripe.js埋め込み(Apple Pay明示ボタン等)を追加する場合に備えて保持しておく。
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ==== Sakana AI ====
SAKANA_AI_API_ENDPOINT=
SAKANA_AI_API_KEY=

# ==== 公式LINE (CL22簡略版: 外部リンク誘導のみ) ====
NEXT_PUBLIC_LINE_OFFICIAL_URL=

# ==== Cron (通知評価バッチ保護用) ====
CRON_SECRET=
