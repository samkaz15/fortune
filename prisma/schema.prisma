// ============================================================
// 錦糸町の少年 — Prisma Schema (CL7: DB設計)
//
// 設計方針（データレイヤー設計書に準拠）:
// - PII（氏名/生年月日/性別/出生時間）は UserProfile に隔離し、
//   User（認証用）とは1:1で分離する。将来の匿名化・削除要求に対応しやすくするため。
// - 利用回数カウンター(1日5回)は本来Redisのアトミックカウンターが最適だが、
//   Postgres単独運用でも動くよう DailyUsage テーブルも用意している(CL3参照)。
//   本番ではRedisを正とし、このテーブルは日次バッチでの整合性チェック用に使う想定。
// - オークション入札(Bid)は楽観ロック(Ticket.version)で同時入札の競合を制御する。
// ============================================================

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------- 認証・ユーザー ----------------

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  passwordHash  String?
  authProvider  String   @default("email") // email | google | apple 等
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime? // 退会時は論理削除→90日後にバッチで物理削除(データレイヤー設計書⑧)

  referralCode     String?  @unique // CL20: 自分の招待コード(初回ログイン時に発行)
  referredByUserId String?  // CL20: 誰の招待で登録したか(あれば)
  lineUserId       String?  @unique // CL22: LINE連携完了後のLINE User ID(未連携はnull)

  profile       UserProfile?
  subscription  Subscription?
  creditBalance CreditBalance?
  sessions      FortuneSession[]
  results       FortuneResult[]
  bids          Bid[]
  notifications NotificationSetting?
  dailyUsages   DailyUsage[]
  pointBalance  PointBalance?
  shrineReviews ShrineReview[]
  karte          UserKarte? // 人生カルテ(AI人生コンパス転換 2026-07-12)
  karteSnapshots KarteSnapshot[]
  lifeEvents     LifeEvent[]

  @@map("users")
}

/// PIIを隔離する専用テーブル。Data Access Layerでも専用Repository経由のみアクセス許可する運用にする。
model UserProfile {
  userId      String   @id
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String // 姓名判断に使用
  birthDate   DateTime // 四柱推命・算命学・ホロスコープに使用
  birthTime   String? // 出生時間（任意、HH:mm）。四柱推命の精度向上に使う
  gender      String? // male | female | other | unspecified
  displayName String? // 表示用ニックネーム（非PII寄り。マイページ等で表示）
  avatar      String? // ユーザー設定アイコン(縮小済みJPEGのdata URL・上限100KB)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("user_profiles")
}

// ---------------- 占いチャット・結果 ----------------

enum ConsultCategory {
  RELATIONSHIP // 人間関係
  SELF // 自分のこと
  BUSINESS // ビジネス
  COMPATIBILITY // 相性(相手情報が必要)
  TODAY // 今日の占い(TOPから直接)
}

model FortuneSession {
  id         String          @id @default(uuid())
  userId     String
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  category   ConsultCategory
  status     String          @default("in_progress") // in_progress | completed | abandoned
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  messages FortuneMessage[]
  result   FortuneResult?

  @@index([userId, createdAt])
  @@map("fortune_sessions")
}

model FortuneMessage {
  id        String         @id @default(uuid())
  sessionId String
  session   FortuneSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String // user | assistant
  content   String
  createdAt DateTime       @default(now())

  @@index([sessionId, createdAt])
  @@map("fortune_messages")
}

/// AI生成データ(診断結果)本体。本文が長い場合はObject Storageへの参照(bodyUrl)に切り替える設計(データレイヤー設計書⑫参照)。
model FortuneResult {
  id            String         @id @default(uuid())
  sessionId     String         @unique
  session       FortuneSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId        String
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  summary       String // 無料開放される要約
  bodyText      String? // 全文（短ければ直接格納）
  bodyUrl       String? // 全文が長い場合はObject Storageのキー/URL

  nextActions   Json // ["行動1","行動2","行動3"] 形式。PC2行/モバイル5行制約はUI側で担保
  scoreOverall  Int? // 0-100。95点以上通知(Phase2)のトリガーに使う
  isUnlocked    Boolean        @default(false) // 課金 or サブスクで解放済みか

  seimeiScore   Json? // 姓名判断の画数スコア内訳
  sanmeiSummary Json? // 算命学の判定内容(社会性/起業適性等)
  shichuSummary Json? // 四柱推命の判定内容
  horoscope     Json? // ホロスコープの判定内容

  weatherContext Json? // 天気(低気圧等)連携時のコンテキスト(CL12)

  engineVersion  Int            @default(1) // D-0a: 占術エンジン世代。過去結果は再計算しない(v1=暫定/v2=正式)

  createdAt     DateTime       @default(now())

  @@index([userId, createdAt])
  @@map("fortune_results")
}

// ---------------- 利用回数カウンター ----------------

/// 「1日5回まで無料」のカウンター。正はRedis(アトミックカウンター)、
/// これは日次バッチ整合性チェック・分析用の記録テーブル。
model DailyUsage {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  usageDate DateTime @db.Date
  count     Int      @default(0)

  @@unique([userId, usageDate])
  @@map("daily_usages")
}

// ---------------- 課金：サブスク ----------------

model Subscription {
  id                   String    @id @default(uuid())
  userId               String    @unique
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  status               String    @default("inactive") // inactive | active | paused | canceled
  planPriceJpy         Int       @default(500) // 初月500円→2ヶ月目以降980円はStripe Price側で管理
  stripeCustomerId     String?
  stripeSubscriptionId String?
  currentPeriodEnd     DateTime?
  canceledAt           DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@map("subscriptions")
}

// ---------------- 課金：追加クレジット ----------------

model CreditBalance {
  userId    String   @id
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance   Int      @default(0) // 5回分＝1クレジットパックとして管理(300円/5回)
  updatedAt DateTime @updatedAt

  transactions CreditTransaction[]

  @@map("credit_balances")
}

model CreditTransaction {
  id              String        @id @default(uuid())
  userId          String
  balance         CreditBalance @relation(fields: [userId], references: [userId], onDelete: Cascade)
  type            String // purchase | consume | refund
  amount          Int // purchase:+5 consume:-1 等
  priceJpy        Int? // purchase時のみ(300円)
  stripePaymentId String?
  createdAt       DateTime      @default(now())

  @@index([userId, createdAt])
  @@map("credit_transactions")
}

// ---------------- 課金：オークション面談チケット ----------------

model AuctionTicket {
  id            String   @id @default(uuid())
  title         String // 例:「7月第2週 個人面談占い」
  description   String
  startPriceJpy Int      @default(1000)
  currentPriceJpy Int    @default(1000)
  status        String   @default("scheduled") // scheduled | open | closed | fulfilled
  opensAt       DateTime
  closesAt      DateTime // opensAtの24時間後を基本とする
  winningBidId  String?  @unique
  winnerUserId  String? // 落札者(終了処理で確定)
  profileText   String? // トークション: 占い師プロフィール(セクション1)
  topics        Json? // トークション: 相談できる内容 string[](セクション2・管理APIで編集可)
  version       Int      @default(0) // 楽観ロック用。入札時にversionをインクリメントし競合を検知する

  bids Bid[]

  @@index([status, closesAt])
  @@map("auction_tickets")
}

model Bid {
  id           String        @id @default(uuid())
  ticketId     String
  ticket       AuctionTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  amountJpy    Int
  status       String        @default("active") // active | outbid | won | refunded
  stripeHoldId String? // 与信保留のID(決済確定は落札後)
  createdAt    DateTime      @default(now())

  @@index([ticketId, amountJpy])
  @@map("bids")
}

// ---------------- 通知 ----------------

model NotificationSetting {
  userId          String   @id
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  pushEnabled     Boolean  @default(true)
  scoreThreshold  Int      @default(95) // 95点以上通知(Phase2)のしきい値。将来ユーザー設定可能にする
  pushSubscription Json?   // Web Push API の PushSubscription(endpoint/keys)。CL22 LINE連携とは別チャネル
  updatedAt       DateTime @updatedAt

  @@map("notification_settings")
}

/// CL17: 通知の送信実績ログ。「送ったつもり」を防ぐため、評価結果は成否・スコアともに必ず記録する。
model NotificationLog {
  id         String   @id @default(uuid())
  userId     String
  type       String // score_threshold(95点通知) | daily_reminder(運気通知) 等
  score      Int?
  channel    String // web_push | line(Phase2, LINE連携完了後) | none(送信手段未設定でスキップ)
  status     String // sent | skipped_no_channel | skipped_below_threshold | failed
  message    String?
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
  @@index([type, createdAt])
  @@map("notification_logs")
}

// ---------------- 監査ログ（追記専用） ----------------

/// PIIアクセス・決済操作・管理者操作を記録する追記専用テーブル(データレイヤー設計書⑨)。
/// アプリケーションコードからUPDATE/DELETEは行わない運用にする。
model AuditLog {
  id         String   @id @default(uuid())
  actorType  String // user | admin | system
  actorId    String?
  action     String // 例: "pii_read", "payment_charge", "admin_update_ticket"
  targetType String?
  targetId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([action, createdAt])
  @@map("audit_logs")
}

// ---------------- CL20: 紹介制度・ポイント制度 ----------------

/// ポイント経済の設計方針(暫定): 1ポイント=1回分の質問クレジットと等価で運用する。
/// 実際の付与量・還元レートはCEOの事業判断が必要(要確認: docs/design/00_ceo_decisions/ 未確定)。
model PointBalance {
  userId    String   @id
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance   Int      @default(0)
  updatedAt DateTime @updatedAt

  transactions PointTransaction[]

  @@map("point_balances")
}

model PointTransaction {
  id        String       @id @default(uuid())
  userId    String
  balance   PointBalance @relation(fields: [userId], references: [userId], onDelete: Cascade)
  type      String // referral_reward | redeem | admin_grant
  amount    Int // 付与は+、消費は-
  reason    String? // 例: "友達招待(referredUserId=...)"
  createdAt DateTime     @default(now())

  @@index([userId, createdAt])
  @@map("point_transactions")
}

// ---------------- CL18: おすすめ神社・神社レビュー ----------------

model Shrine {
  id            String   @id @default(uuid())
  name          String
  prefecture    String
  city          String
  tags          Json // ["恋愛","金運","仕事運"] 等の悩みタグ(IA設計書⑤のタグ設計に準拠)
  generalInfo   String // 一般情報(住所・由緒等、参拝前に配信する内容)
  media         Json? // UI仕様v5: { imageUrl?, videoUrl?(YouTube埋込URL), sns?: { x?, instagram?, tiktok? } }
  latitude      Float?
  longitude     Float?
  createdAt     DateTime @default(now())

  reviews ShrineReview[]

  @@map("shrines")
}

/// プロジェクト概要の運用フロー通り:
/// 一般情報 → CEO実参拝 → レビュー追加 → (Phase3で)AI反映 → ユーザーへ配信
model ShrineReview {
  id          String   @id @default(uuid())
  shrineId    String
  shrine      Shrine   @relation(fields: [shrineId], references: [id], onDelete: Cascade)
  authorType  String   @default("ceo") // ceo(CEO本人の参拝レビュー) | ai(Phase3で自動反映する場合)
  authorUserId String?
  author      User?    @relation(fields: [authorUserId], references: [id])
  visitedAt   DateTime?
  // GPT8の5ブロック構成に対応するJSON( block1〜block5 )
  blocks      Json
  createdAt   DateTime @default(now())

  @@index([shrineId, createdAt])
  @@map("shrine_reviews")
}

// ---------------- 意思決定レポート (CEO_UPDATE 2026-07-03) ----------------

/// 「今日の意思決定レポート」。1ユーザー1日1件。スコアはルールベースで確定し、AIは変更しない。
model DailyReport {
  id             String   @id @default(uuid())
  userId         String
  reportDate     DateTime @db.Date
  period         String   @default("today") // today|week|month|nextMonth(2026-07-11 Phase1指示A・要件②原因B対策)
  score          Int
  stars          Int
  keywords       Json // {userTheme, environment, fortune}
  summary        String
  cautions       Json // [string, string, string]
  advice         String
  todayAction    String
  scoreBreakdown Json // {base, envModifier, themeBonus} 監査・スコアリング改善用
  details        Json? // 出来事/注意/おすすめ各3つ(理由付き)+総評(要件⑤ 2026-07-08)。旧行はnull
  generatedBy    String   @default("llm") // llm | fallback
  engineVersion  Int      @default(1) // D-0a: 占術エンジン世代。過去レポートは再計算しない
  createdAt      DateTime @default(now())

  @@unique([userId, reportDate, period])
  @@map("daily_reports")
}

/// RAG知識ベース。会話ログの生テキストではなく構造化サマリを保存する(仕様書「会話ログの活用」準拠)。
/// 検索は初期は pg_trgm 全文検索(manual_life_karte.sql のGINインデックス参照)。
/// 将来 pgvector へ拡張する場合は embedding 列を追加し、検索実装(karte-repository)側だけ差し替える。
model KnowledgeEntry {
  id                String          @id @default(uuid())
  userId            String
  sessionId         String          @unique
  category          ConsultCategory
  userConcern       String
  divinationSummary String
  finalAdvice       String
  nextAction        String
  tags              Json // string[]
  emotionalTone     String? // positive | negative | mixed | neutral (AI人生コンパス 2026-07-12)
  importance        Int             @default(3) // 1-5。RAG想起の優先度(高いほど思い出されやすい)
  lastReferencedAt  DateTime? // 最後にRAGで参照された日時。記憶の鮮度管理に使う
  createdAt         DateTime        @default(now())

  @@index([userId, createdAt])
  @@map("knowledge_entries")
}

// ---------------- 人生カルテ (AI人生コンパス転換 2026-07-12) ----------------

/// 人生カルテ本体(User 1:1)。「AIがこの人を現在どう理解しているか」のスナップショット。
/// 更新はチャット完了時・日次バッチのパイプライン(Step3)から行い、更新前の状態は
/// KarteSnapshot へ退避してから上書きする(変遷を失わないための運用ルール)。
model UserKarte {
  userId           String   @id
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  basicPersonality Json? // 基本性格 { fromDivination: {...}, fromConversation: {...} }
  concernTrends    Json? // 悩み傾向 { categoryWeights: {RELATIONSHIP: 0.4,...}, recurringThemes: string[] }
  lifeCycle        Json? // 人生周期(四柱大運・年運のキャッシュ。再計算コスト削減用)
  values           Json? // 価値観・大切にしていること string[]
  aiInsights       String? // AI分析(自由記述。カルテ画面「AI分析」欄にそのまま表示)
  version          Int      @default(1) // KarteSnapshot.version と同期して単調増加
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("user_kartes")
}

/// カルテの変遷履歴(追記専用)。「AIの理解がどう深まったか」を時系列で残す。
/// UPDATE/DELETEはアプリケーションから行わない(AuditLogと同じ運用)。
model KarteSnapshot {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  version   Int // 退避時点の UserKarte.version
  data      Json // UserKarte 全カラムのスナップショット
  trigger   String // session_completed | daily_batch | manual
  createdAt DateTime @default(now())

  @@unique([userId, version])
  @@map("karte_snapshots")
}

/// 会話から抽出した人生イベント。「占い結果の羅列」ではなく「人生の変遷」として保存する。
/// 抽出はチャットパイプライン(Step3)のパーソナリティ分析ステップで行う。
model LifeEvent {
  id          String          @id @default(uuid())
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId   String? // 抽出元の FortuneSession.id(緩結合。セッション削除でも人生イベントは残す)
  occurredAt  DateTime? // 出来事が起きた時期(会話から推定。不明なら null = 「時期不明」表示)
  category    ConsultCategory
  title       String // 例:「転職を決意した」「長年の友人と和解した」
  description String?
  emotion     String? // positive | negative | mixed | neutral
  importance  Int             @default(3) // 1-5。カルテ画面の表示優先度・RAG想起優先度
  createdAt   DateTime        @default(now())

  @@index([userId, occurredAt])
  @@index([userId, createdAt])
  @@map("life_events")
}

/// CL25: 分析イベント(DWH基盤)。トークン使用量を含む全行動ログ。GM10「トークン数でコスト管理」準拠。
model AnalyticsEvent {
  id        String   @id @default(uuid())
  userId    String?
  name      String // chat_message / report_generated / payment_succeeded / experiment_exposure など
  props     Json? // 任意のプロパティ(category, tokens, amount等)
  createdAt DateTime @default(now())

  @@index([name, createdAt])
  @@index([userId, createdAt])
  @@map("analytics_events")
}

/// CL26: AI Feature Store。Sakana AIへ渡す特徴量をバージョン管理する。GM10「コンテンツの資産化」準拠。
model UserFeature {
  id               String   @id @default(uuid())
  userId           String
  version          Int // 同一ユーザー内で単調増加
  consultCount30d  Int
  favoriteCategory String? // 直近30日で最多の相談カテゴリ
  avgScore30d      Float?
  activeDays30d    Int
  isSubscriber     Boolean
  computedAt       DateTime @default(now())

  @@unique([userId, version])
  @@index([userId, computedAt])
  @@map("user_features")
}

/// CL31: A/Bテスト割当。userIdハッシュによる決定論的バケット(再現可能・統計評価用)。
model ExperimentAssignment {
  id            String   @id @default(uuid())
  userId        String
  experimentKey String
  variant       String
  assignedAt    DateTime @default(now())

  @@unique([userId, experimentKey])
  @@index([experimentKey, variant])
  @@map("experiment_assignments")
}

/// トークション: レビュー(星+コメント)。悪い評価も削除せず表示する(透明性重視・仕様書§3)。
model AuctionReview {
  id        String   @id @default(uuid())
  ticketId  String
  userId    String
  rating    Int // 1-5
  comment   String
  createdAt DateTime @default(now())

  @@unique([ticketId, userId])
  @@index([createdAt])
  @@map("auction_reviews")
}

/// トークション: 日程予約。決済完了後、カレンダー空き枠から選択して確定(仕様書§日程予約)。
model AuctionReservation {
  id          String   @id @default(uuid())
  ticketId    String   @unique
  userId      String
  scheduledAt DateTime
  status      String   @default("reserved") // reserved | done | canceled
  createdAt   DateTime @default(now())

  @@index([userId])
  @@map("auction_reservations")
}
